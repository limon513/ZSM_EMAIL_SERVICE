# Gmail SMTP (use an App Password — not your main Gmail password)
# Go to: myaccount.google.com/apppasswords to generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=farhanfardid62@gmail.com
SMTP_PASS=your_16_char_app_password_no_spaces

# Where contact form emails are delivered
MAIL_TO=farhanfardid62@gmail.com

# Secret key — ZSM Vercel app must send this in x-api-key header
# Generate one: openssl rand -hex 32
API_SECRET=your_strong_random_secret_here

# Comma-separated list of allowed origins (your Vercel domain)
ALLOWED_ORIGINS=https://zsmtransport.bitnbyteit.com
