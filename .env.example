# Resend API key — get it free at resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# "From" address — must be from a verified domain in your Resend dashboard
# Until you verify a domain, use: onboarding@resend.dev (can only send to your own email)
RESEND_FROM=ZSM Transport Agency <onboarding@resend.dev>

# Where contact form emails are delivered
MAIL_TO=zsmtransportagency@gmail.com

# Secret key — must match EMAIL_SERVICE_SECRET in Vercel env vars
API_SECRET=your_strong_random_secret_here

# Comma-separated allowed origins
ALLOWED_ORIGINS=https://zsmtransport.bitnbyteit.com

